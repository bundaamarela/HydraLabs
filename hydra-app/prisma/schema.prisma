datasource db {
  provider = "sqlite"
  url      = "file:./hydra.db"
}

generator client {
  provider = "prisma-client-js"
}

model Session {
  id        String     @id @default(cuid())
  title     String
  query     String
  mode      String
  voices    Int        @default(8)
  synthesis String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  responses Response[]
  tags      Tag[]
}

model Response {
  id        String  @id @default(cuid())
  sessionId String
  model     String
  content   String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String  @id @default(cuid())
  name      String
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
